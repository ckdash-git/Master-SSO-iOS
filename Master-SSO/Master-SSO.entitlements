<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by MSAL broker to store/retrieve its cryptographic key securely. -->
    <!-- Without this, Keychain operations return errSecMissingEntitlement (-34018). -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.cachatto.Master-SSO</string>
    </array>
</dict>
</plist>
